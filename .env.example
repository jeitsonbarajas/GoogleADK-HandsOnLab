# Archivo de ejemplo para variables de entorno
# Copia este archivo a .env y completa con tus valores

# ===========================================
# API KEYS (REQUERIDAS)
# ===========================================

# Google API Key para Gemini (REQUERIDO)
# Obtener en: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyARK9S3ZgMKnHhwSZ2kDxbD4mIJpFl-7ag

# ===========================================
# CONFIGURACIÓN DEL SERVIDOR
# ===========================================

# Puerto principal (8080 por defecto)
PORT=8080

# URL del adapter server (para desarrollo local)
ADAPTER_SERVER_URL=http://127.0.0.1:8080

# Puerto para ADK Web (8000 por defecto)
ADK_WEB_PORT=8000

# ===========================================
# CONFIGURACIÓN DE ENTORNO
# ===========================================

# Entorno de ejecución (development|production|gcp|docker)
ENVIRONMENT=development

# Python path (automático en Docker)
PYTHONPATH=/app

# ===========================================
# CONFIGURACIONES OPCIONALES
# ===========================================

# Para Google Cloud (automático en Cloud Run)
# GOOGLE_CLOUD_PROJECT=tu-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Para Vertex AI (alternativa a GOOGLE_API_KEY)
# USE_VERTEX_AI=true

# Para depuración
# DEBUG=true
# LOG_LEVEL=debug

# ===========================================
# INSTRUCCIONES DE USO
# ===========================================

# 1. Copia este archivo:
#    cp .env.example .env

# 2. Configura GOOGLE_API_KEY

# 3. Para desarrollo local:
#    python agents-poc/main.py

# 4. Para despliegue:
#    - GCP: Usa Google Secret Manager
#    - Docker: Usa este archivo .env